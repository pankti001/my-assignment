{
	"name": "my-assignment",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "prettier --check . && turbo run lint",
		"format": "prettier --write \"**/*.{ts,tsx,md}\" && prettier --write .",
		"check-types": "turbo run check-types"
	},
	"devDependencies": {
		"@types/bcryptjs": "^2.4.6",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
