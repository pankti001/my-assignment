		"typescript": "5.9.2"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "npm@11.6.2",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"dependencies": {
		"@threlte/core": "^8.5.16",
		"@threlte/extras": "^9.21.0",
		"bcryptjs": "^3.0.3",
		"three": "^0.184.0"
	}
